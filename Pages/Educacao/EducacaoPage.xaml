<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="AppReciclique.EducacaoPage"
    NavigationPage.HasNavigationBar="False"
    BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="Auto,*,Auto">

        <!--  TOPO (ROW 0) -->
        <VerticalStackLayout BackgroundColor="#2E7D32" Padding="10" Grid.Row="0">

            <Label Text="←"
                   TextColor="White"
                   FontSize="20">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnVoltarClicked"/>
                </Label.GestureRecognizers>
            </Label>

            <Label Text="TRILHA VERDE"
                   TextColor="White"
                   FontSize="20"
                   FontAttributes="Bold"
                   HorizontalOptions="StartAndExpand"/>

        </VerticalStackLayout>

        <!-- 📚 CONTEÚDO (ROW 1) -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="15" Padding="10">

                <!-- NÍVEL 1 -->
                <Frame CornerRadius="12" BackgroundColor="White">
                    <VerticalStackLayout>
                      
                        <Label Text="Nível 1 — O Básico da Reciclagem" FontAttributes="Bold"/>
                        <Button Text="Acessar" FontAttributes="Bold" Clicked="Nivel1_Clicked" BackgroundColor="#66BB6A"/>
                        <Image Source="nivel1.jpg"
                                HeightRequest="100"
                                Aspect="AspectFill"
                                Margin="0,10,0,0"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- NÍVEL 2 -->
                <Frame CornerRadius="12" BackgroundColor="White">
                    <VerticalStackLayout>
                
                        <Label Text="Nível 2 — Lixo Organico e Alimento" FontAttributes="Bold"/>
                        <Button Text="Acessar" FontAttributes="Bold" Clicked="Nivel2_Clicked" BackgroundColor="#66BB6A" />
                        <Image Source="nivel2.png"
                                HeightRequest="100"
                                Aspect="AspectFill"
                                Margin="0,10,0,0"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- NÍVEL 3 -->
                <Frame CornerRadius="12" BackgroundColor="White">
                    <VerticalStackLayout>
                       
                        <Label Text="Nível 3 — Resíduos Perigosos" FontAttributes="Bold"/>
                        <Button Text="Acessar" FontAttributes="Bold" Clicked="Nivel3_Clicked" BackgroundColor="#66BB6A" />
                        <Image Source="nivel3.png"
                                HeightRequest="100"
                                Aspect="AspectFill"
                                Margin="0,10,0,0"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- NÍVEL 4 -->
                <Frame CornerRadius="12" BackgroundColor="White">
                    <VerticalStackLayout>
                        
                        <Label Text="Nível 4 — Entulhos e Materiais Grandes" FontAttributes="Bold"/>
                        <Button Text="Acessar" FontAttributes="Bold" Clicked="Nivel4_Clicked" BackgroundColor="#66BB6A" />
                        <Image Source="nivel4.png"
                                HeightRequest="100"
                                Aspect="AspectFill"
                                Margin="0,10,0,0"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- NÍVEL 5 -->
                <Frame CornerRadius="12" BackgroundColor="White">
                    <VerticalStackLayout>
                        
                        <Label Text="Nível 5 — Ação na Prática (Multirão)" FontAttributes="Bold"/>
                        <Button Text="Acessar" FontAttributes="Bold" Clicked="Nivel5_Clicked" BackgroundColor="#66BB6A" />
                        <Image Source="nivel5.png"
                                HeightRequest="120"
                                Aspect="AspectFill"
                                Margin="0,10,0,0"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- NÍVEL 6 -->
                <Frame CornerRadius="12" BackgroundColor="White">
                    <VerticalStackLayout>
                        
                        <Label Text="Nível 6 — Reultilização Criativa" FontAttributes="Bold"/>
                        <Button Text="Acessar" Clicked="Nivel6_Clicked" BackgroundColor="#66BB6A"/>
                          
                        <Image Source="nivel6.png"
                                HeightRequest="120"
                                Aspect="AspectFill"
                                    Margin="0,10,0,0"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- BÔNUS -->
                <Frame CornerRadius="12" BackgroundColor="White">
                    <VerticalStackLayout>
                       
                        <Label Text="Bônus — Casa Sustentavél" FontAttributes="Bold"/>
                        <Button Text="Acessar" FontAttributes="Bold" Clicked="Bonus_Clicked"
                                BackgroundColor= "#66BB6A" 
                                TextColor="White"/>
                            <Image Source="bonus.png"
                                HeightRequest="120"
                                Aspect="AspectFill"
                                    Margin="0,10,0,0"/>
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

        <!-- MENU INFERIOR (ROW 2) -->
        <Grid Grid.Row="2" BackgroundColor="White" Padding="10">

            <BoxView HeightRequest="2"
                     BackgroundColor="#2E7D32"
                     VerticalOptions="Start"/>

            <VerticalStackLayout HorizontalOptions="Start"
                                 Margin="10,10,0,0">

                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeClicked"/>
                </VerticalStackLayout.GestureRecognizers>

                <Label Text="🏠"
                       FontSize="24"
                       HorizontalOptions="Center"/>

                <Label Text="Home"
                       FontSize="10"
                       HorizontalOptions="Center"/>

            </VerticalStackLayout>

        </Grid>

    </Grid>

</ContentPage>