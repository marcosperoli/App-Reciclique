<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="AppReciclique.Pages.Educacao.Nivel3Page"
    NavigationPage.HasNavigationBar="False"
    BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- TOPO (ROW 0) -->
        <VerticalStackLayout BackgroundColor="#2E7D32" Padding="10" Grid.Row="0">

            <Label Text="←"
           TextColor="White"
           FontSize="20">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnVoltarClicked"/>
                </Label.GestureRecognizers>
            </Label>

            <Label Text="NÍVEL 3 — RESÍDUOS PERIGOSOS"
           TextColor="white"
           FontSize="20"/>
        </VerticalStackLayout>



        <!-- CONTEÚDO (ROW 1) -->


        <!-- MENU HOME (ROW 2) -->
        <Grid Grid.Row="2" BackgroundColor="White" Padding="10">

            <!-- LINHA VERDE -->
            <BoxView HeightRequest="2"
             BackgroundColor="#2E7D32"
             VerticalOptions="Start"/>

            <!-- BOTÃO HOME -->
            <VerticalStackLayout HorizontalOptions="Start"
                         Margin="10,10,0,0">

                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeClicked"/>
                </VerticalStackLayout.GestureRecognizers>

                <Label Text="🏠"
               FontSize="24"
               HorizontalOptions="Center"/>

                <Label Text="Home"
               FontSize="10"
               HorizontalOptions="Center"/>

            </VerticalStackLayout>

        </Grid>

    </Grid>
</ContentPage>