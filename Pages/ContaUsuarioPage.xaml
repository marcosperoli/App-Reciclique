<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="AppReciclique.ContaUsuarioPage"
    NavigationPage.HasNavigationBar="False"
    BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- 🔝 TOPO -->
        <VerticalStackLayout 
            BackgroundColor="#2E7D32" 
            Padding="15"
            Spacing="10"
            Grid.Row="0">

            <Label Text="←"
                   TextColor="White"
                   FontSize="20">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnVoltarClicked"/>
                </Label.GestureRecognizers>
            </Label>

            <Label Text="MINHA CONTA"
                   TextColor="White"
                   FontSize="20"
                   FontAttributes="Bold"/>
        </VerticalStackLayout>


        <!-- 📚 CONTEÚDO -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="30" Spacing="15">

                <Frame BackgroundColor="White"
                       CornerRadius="12"
                       Padding="15">

                    <VerticalStackLayout Spacing="10">

                        <Label Text="Nome: João da Silva"
                               FontSize="16"
                               TextColor="#1B5E20"/>

                        <Label Text="Email: usuario@email.com"
                               FontSize="16"
                               TextColor="#1B5E20"/>

                        <Label Text="Data de nascimento: 17/01/1989"
                               FontSize="16"
                               TextColor="#1B5E20"/>

                        <Label Text="Telefone: (14) 98841-5896"
                               FontSize="16"
                               TextColor="#1B5E20"/>

                    </VerticalStackLayout>

                </Frame>

            </VerticalStackLayout>
        </ScrollView>


        <!-- 🏠 MENU HOME -->
        <Grid Grid.Row="2" BackgroundColor="White" Padding="10">

            <!-- LINHA VERDE -->
            <BoxView HeightRequest="2"
                     BackgroundColor="#2E7D32"
                     VerticalOptions="Start"/>

            <!-- BOTÃO HOME -->
            <VerticalStackLayout HorizontalOptions="Start"
                                 Margin="10,10,0,0">

                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeClicked"/>
                </VerticalStackLayout.GestureRecognizers>

                <Label Text="🏠"
                       FontSize="24"
                       HorizontalOptions="Center"/>

                <Label Text="Home"
                       FontSize="10"
                       HorizontalOptions="Center"/>

            </VerticalStackLayout>

        </Grid>

    </Grid>
</ContentPage>