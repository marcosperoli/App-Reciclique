<ContentPage  
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="AppReciclique.AgendamentoPage"
    NavigationPage.HasNavigationBar="False"
    BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- TOPO -->
        <VerticalStackLayout BackgroundColor="#2E7D32" Padding="10" Grid.Row="0">

            <Label Text="←"
                   TextColor="White"
                   FontSize="20">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnVoltarClicked"/>
                </Label.GestureRecognizers>
            </Label>

            <Label Text="Agendamento Coleta"
                   TextColor="White"
                   FontSize="20"/>
        </VerticalStackLayout>

        <!-- CONTEÚDO -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="25" Spacing="15">

                <!-- TIPO DE COLETA -->
                <Label Text="Tipo de Coleta"/>
                <Picker x:Name="pickerTipo">
                    <Picker.Items>
                        <x:String>Coleta Normal</x:String>
                        <x:String>Super Coleta</x:String>
                    </Picker.Items>
                </Picker>

                <!-- ENDEREÇO -->
                <Label Text="CEP"/>
                <Entry x:Name="txtCep" Placeholder="Digite o CEP" Completed="OnBuscarCep"/>
                <Label Text="Endereço"/>
                <Entry x:Name="txtEndereco" Placeholder="Digite seu endereço"/>

                <!-- NÚMERO -->
                <Label Text="Número"/>
                <Entry x:Name="txtNumero" Placeholder="Número"/>

                <!-- COMPLEMENTO -->
                <Label Text="Complemento"/>
                <Entry x:Name="txtComplemento" Placeholder="Ex: Casa, Apto, Bloco"/>

                <!-- DATA -->
                <Label Text="Data"/>
                <DatePicker x:Name="dataColeta"/>

                <!-- HORA -->
                <Label Text="Hora"/>
                <TimePicker x:Name="horaColeta"/>

                <!-- TELEFONE -->
                <Label Text="Telefone"/>
                <Entry x:Name="txtTelefone" Keyboard="Telephone"/>

                <!-- OBSERVAÇÕES -->
                <Label Text="Observações"/>
                <Editor x:Name="txtObs" HeightRequest="80"/>

                <!-- BOTÃO -->
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10" Margin="0,20,0,0">

                    <!-- AGENDAR -->
                    <Button Text="Agendar"
                    BackgroundColor="#2E7D32" 
                    TextColor="White"
                    CornerRadius="10"
                    HeightRequest="45"
                    Shadow="Small"
                    Grid.Column="0"
                    Clicked="OnAgendarClicked"/>

                    <!-- EDITAR -->
                    <Button Text="Editar"
                    BackgroundColor="#FFC107"
                    TextColor="Black"
                    CornerRadius="10"
                    HeightRequest="45"
                    Shadow="Small"
                    Grid.Column="1"
                    Clicked="OnEditarClicked"/>

                    <!-- NOVO -->
                    <Button Text="Novo"
                    BackgroundColor="#2196F3"
                    TextColor="White"
                    CornerRadius="10"
                    HeightRequest="45"
                    Shadow="Small"
                    Grid.Column="2"
                    Clicked="OnNovoClicked"/>

                </Grid>

            </VerticalStackLayout>
        </ScrollView>

        <Label x:Name="lblSucesso"
          Text="Agendamento salvo com sucesso! ✅"
          BackgroundColor="#2E7D32"
          TextColor="White"
          HorizontalOptions="Fill"
          Padding="10"
          IsVisible="False"
          Opacity="0"/>

        <!-- MENU INFERIOR -->
        <Grid Grid.Row="2" BackgroundColor="White" Padding="10">

            <!-- LINHA VERDE -->
            <BoxView HeightRequest="2"
                     BackgroundColor="#2E7D32"
                     VerticalOptions="Start"/>

            <!-- HOME -->
            <VerticalStackLayout HorizontalOptions="Start"
                                 Margin="10,10,0,0">

                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeClicked"/>
                </VerticalStackLayout.GestureRecognizers>

                <Label Text="🏠"
                       FontSize="24"
                       HorizontalOptions="Center"/>

                <Label Text="Home"
                       FontSize="10"
                       HorizontalOptions="Center"/>

            </VerticalStackLayout>

        </Grid>

    </Grid>

</ContentPage>