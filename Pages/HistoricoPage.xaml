<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:AppReciclique.Models"
    x:Class="AppReciclique.HistoricoPage"
    NavigationPage.HasNavigationBar="False"
    BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- 🔝 TOPO -->
        <VerticalStackLayout BackgroundColor="#2E7D32" Padding="10" Grid.Row="0">

            <Label Text="←"
                   TextColor="White"
                   FontSize="20">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnVoltarClicked"/>
                </Label.GestureRecognizers>
            </Label>

            <Label Text="Histórico de Atividades"
                   TextColor="White"
                   FontSize="20"
                   HorizontalOptions="StartAndExpand"/>

        </VerticalStackLayout>

        <!-- 📲 CONTEÚDO -->
        <CollectionView Grid.Row="1"
                        x:Name="listaHistorico"
                        Margin="10">

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Agendamento">
                    <Frame Margin="5"
                           Padding="10"
                           BorderColor="#2E7D32"
                           CornerRadius="10">

                        <VerticalStackLayout Spacing="5">

                            <Label Text="{Binding Tipo}"
                                   FontAttributes="Bold"
                                   TextColor="#2E7D32"/>

                            <Label Text="{Binding Endereco}"
                                   FontSize="13"/>

                            <Label Text="{Binding Data, StringFormat='Data: {0:dd/MM/yyyy}'}"
                                   FontSize="12"/>

                            <Label Text="{Binding Hora}"
                                   FontSize="12"/>

                        </VerticalStackLayout>

                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

        <!-- 🔽 MENU INFERIOR -->
        <Grid Grid.Row="2" BackgroundColor="White" Padding="10">

            <BoxView HeightRequest="2"
                     BackgroundColor="#2E7D32"
                     VerticalOptions="Start"/>

            <VerticalStackLayout HorizontalOptions="Start"
                                 Margin="10,10,0,0">

                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeClicked"/>
                </VerticalStackLayout.GestureRecognizers>

                <Label Text="🏠"
                       FontSize="24"
                       HorizontalOptions="Center"/>

                <Label Text="Home"
                       FontSize="10"
                       HorizontalOptions="Center"/>

            </VerticalStackLayout>

        </Grid>

    </Grid>

</ContentPage>