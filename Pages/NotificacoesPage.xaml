<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="AppReciclique.NotificacoesPage"
    NavigationPage.HasNavigationBar="False"
    BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- TOPO (ROW 0) -->
        <VerticalStackLayout BackgroundColor="#2E7D32" Padding="10" Grid.Row="0">

            <Label Text="←"
                   TextColor="White"
                   FontSize="20">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnVoltarClicked"/>
                </Label.GestureRecognizers>
            </Label>

            <Label Text="Últimos Avisos"
                   TextColor="White"
                   FontSize="20"
                   HorizontalOptions="StartAndExpand"/>

        </VerticalStackLayout>

        <!-- CONTEÚDO (ROW 1) -->
        <VerticalStackLayout Grid.Row="1" Padding="20" Spacing="15">

            <!-- ALTERADO PARA O PEDIDO:
                 aqui aparecem as notificações do sistema -->
            <CollectionView x:Name="cvNotificacoes">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BackgroundColor="White"
                               CornerRadius="12"
                               Padding="12"
                               Margin="0,5">
                            <Label Text="{Binding .}"
                                   TextColor="#1B5E20"
                                   FontSize="16" />
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>

        <!-- MENU INFERIOR (ROW 2) -->
        <Grid Grid.Row="2" BackgroundColor="White" Padding="10">

            <!-- LINHA VERDE -->
            <BoxView HeightRequest="2"
                     BackgroundColor="#2E7D32"
                     VerticalOptions="Start"/>

            <!-- HOME -->
            <VerticalStackLayout HorizontalOptions="Start"
                                 Margin="10,10,0,0">

                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeClicked"/>
                </VerticalStackLayout.GestureRecognizers>

                <Label Text="🏠"
                       FontSize="24"
                       HorizontalOptions="Center"/>

                <Label Text="Home"
                       FontSize="10"
                       HorizontalOptions="Center"/>

            </VerticalStackLayout>

        </Grid>

    </Grid>

</ContentPage>