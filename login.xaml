<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppReciclique.LoginPage"
             Title="Login">

    <VerticalStackLayout Padding="28" Spacing="15">

        <Image
            Source="logo.png"
            HorizontalOptions="Center"
            HeightRequest="120"
            Aspect="AspectFit" />

       <Frame CornerRadius="10"
               BackgroundColor="White"
               Padding="5"
              Margin="5">

         <Entry
            x:Name="txtEmail"
            Placeholder="Digite seu e-mail"
            Keyboard="Email"
            Margin="5"
            TextColor="Black"
            PlaceholderColor="Gray"/>
           
      </Frame>

      <Frame CornerRadius="5"
              BackgroundColor="White"
              Padding="5"
              Margin="5">

            <Entry
            x:Name="txtSenha"
            Placeholder="Digite sua senha"
            IsPassword="True"
            Margin="5"
            TextColor="Black"
            PlaceholderColor="Gray"/>

       </Frame>

        <Button
            Text="Entrar"
            Clicked="OnLoginClicked"/>

    </VerticalStackLayout>

</ContentPage>