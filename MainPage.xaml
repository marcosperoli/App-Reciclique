<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppReciclique.MainPage"
             BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- 🔝 TOPO -->
        <VerticalStackLayout Padding="15" BackgroundColor="White" Grid.Row="0" Spacing="5">

            <!-- LOGO GRANDE -->
            <Image Source="logo.png"
                   HeightRequest="120"
                   HorizontalOptions="Center"/>

            <!-- TEXTO -->
            <Label Text="Olá, Pamela"
                   FontSize="16"
                   HorizontalOptions="Center"/>

        </VerticalStackLayout>

        <!-- 📲 CONTEÚDO -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="15" Spacing="20">

                <!-- 🔘 MENU PRINCIPAL -->
                <Grid ColumnSpacing="10">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- AGENDAR -->
                    <Frame Grid.Column="0" BackgroundColor="#E8F5E9" CornerRadius="12" Padding="10"
                           BorderColor="#2E7D32"
                            HasShadow="False">

                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnAgendarClicked"/>
                        </Frame.GestureRecognizers>
                        
                        <VerticalStackLayout HorizontalOptions="Center">
                            <Label Text="📅" FontSize="28" HorizontalOptions="Center"/>
                            <Label Text="Agendar" FontSize="11" FontAttributes="Bold" TextColor="#2E7D32" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Frame>

                    <!-- PONTOS -->
                    <Frame Grid.Column="1" BackgroundColor="#E8F5E9" CornerRadius="12" Padding="10"
                           BorderColor="#2E7D32"
                           HasShadow="False">

                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnPontosClicked"/>
                        </Frame.GestureRecognizers>
                        
                        <VerticalStackLayout HorizontalOptions="Center">
                            <Label Text="🏆" FontSize="28" HorizontalOptions="Center"/>
                            <Label Text="Pontos" FontSize="11" FontAttributes="Bold" TextColor="#2E7D32" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Frame>

                    <!-- HISTÓRICO -->
                    <Frame Grid.Column="2" BackgroundColor="#E8F5E9" CornerRadius="12" Padding="10"
                           BorderColor="#2E7D32"
                           HasShadow="False">

                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnHistoricoClicked"/>
                        </Frame.GestureRecognizers>
                        
                        <VerticalStackLayout HorizontalOptions="Center">
                            <Label Text="📋" FontSize="28" HorizontalOptions="Center"/>
                            <Label Text="Histórico" FontSize="11" FontAttributes="Bold" TextColor="#2E7D32" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Frame>

                    <!-- EDUCAÇÃO -->
                    <Frame Grid.Column="3" BackgroundColor="#E8F5E9" CornerRadius="12" Padding="10"
                           BorderColor="#2E7D32"
                           HasShadow="False">

                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnEducacaoClicked"/>
                        </Frame.GestureRecognizers>
                        
                        <VerticalStackLayout HorizontalOptions="Center">
                            <Label Text="♻️" FontSize="28" HorizontalOptions="Center"/>
                            <Label Text="Educação" FontSize="11" FontAttributes="Bold" TextColor="#2E7D32" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Frame>

                </Grid>

                <!-- 📦 ÚLTIMO AGENDAMENTO -->
                <Frame BackgroundColor="White" CornerRadius="10"
                       BorderColor="#2E7D32"
                       HasShadow="False">
                    <Label Text="Último agendamento"/>
                </Frame>

                <!-- 📢 PROPAGANDA -->
                <Frame BackgroundColor="#E0E0E0"
                       HeightRequest="120"
                       CornerRadius="10">
                    <Label Text="Espaço para propaganda"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

        <!-- 🔽 MENU INFERIOR -->
        <Grid Grid.Row="2" BackgroundColor="White" Padding="10">

            <!-- LINHA VERDE EM CIMA -->
            <Grid.RowDefinitions>
                <RowDefinition Height="2"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <BoxView BackgroundColor="#2E7D32" Grid.Row="0"/>

            <Grid Grid.Row="1" ColumnSpacing="10">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- HOME -->
                <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center">

                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnHomeClicked"/>
                    </VerticalStackLayout.GestureRecognizers>
                    
                    <Label Text="🏠" FontSize="24" HorizontalOptions="Center"/>
                    <Label Text="Home" FontSize="10" HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <!-- MAPA -->
                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">

                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMapaClicked"/>
                    </VerticalStackLayout.GestureRecognizers>
                    
                    <Label Text="📍" FontSize="24" HorizontalOptions="Center"/>
                    <Label Text="Mapa" FontSize="10" HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <!-- AVISOS -->
                <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center">

                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnNotificacoesClicked"/>
                    </VerticalStackLayout.GestureRecognizers>
                    
                    <Label Text="🔔" FontSize="24" HorizontalOptions="Center"/>
                    <Label Text="Avisos" FontSize="10" HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <!-- CONTA -->
                <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center">

                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnContaClicked"/>
                    </VerticalStackLayout.GestureRecognizers>
                    
                    <Label Text="👤" FontSize="24" HorizontalOptions="Center"/>
                    <Label Text="Conta" FontSize="10" HorizontalOptions="Center"/>
                </VerticalStackLayout>

            </Grid>

        </Grid>

    </Grid>

</ContentPage>
