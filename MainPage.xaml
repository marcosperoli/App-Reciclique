<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppReciclique.MainPage"
             BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- 🔝 TOPO -->
        <VerticalStackLayout Padding="15" BackgroundColor="White" Grid.Row="0" Spacing="5">

            <!-- LOGO GRANDE -->
            <Image Source="logo.png"
                   HeightRequest="120"
                   HorizontalOptions="Center"/>

            <!-- TEXTO -->
            <Label Text="Olá, Pamela"
                   FontSize="16"
                   HorizontalOptions="Center"/>

        </VerticalStackLayout>

        <!-- 📲 CONTEÚDO -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="15" Spacing="20">

                <!-- 🔘 MENU PRINCIPAL -->
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- AGENDAR -->
                    <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center">
                        <Label Text="📅" FontSize="30" HorizontalOptions="Center"/>
                        <Label Text="Agendar" FontSize="11" HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                    <!-- PONTOS -->
                    <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                        <Label Text="📍" FontSize="30" HorizontalOptions="Center"/>
                        <Label Text="Pontos" FontSize="11" HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                    <!-- HISTÓRICO -->
                    <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center">
                        <Label Text="🕘" FontSize="30" HorizontalOptions="Center"/>
                        <Label Text="Histórico" FontSize="11" HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                    <!-- EDUCAÇÃO -->
                    <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center">
                        <Label Text="🌱" FontSize="30" HorizontalOptions="Center"/>
                        <Label Text="Educação" FontSize="11" HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                </Grid>

                <!-- 📦 ÚLTIMO AGENDAMENTO -->
                <Frame BackgroundColor="White" CornerRadius="10">
                    <Label Text="Último agendamento"/>
                </Frame>

                <!-- 📢 PROPAGANDA -->
                <Frame BackgroundColor="#E0E0E0"
                       HeightRequest="120"
                       CornerRadius="10">
                    <Label Text="Espaço para propaganda"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

        <!-- 🔽 MENU INFERIOR -->
        <Grid Grid.Row="2" BackgroundColor="White" Padding="10">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center">
                <Label Text="🏠" FontSize="26"/>
                <Label Text="Home" FontSize="10"/>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                <Label Text="📍" FontSize="26"/>
                <Label Text="Mapa" FontSize="10"/>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center">
                <Label Text="🔔" FontSize="26"/>
                <Label Text="Avisos" FontSize="10"/>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center">
                <Label Text="👤" FontSize="26"/>
                <Label Text="Conta" FontSize="10"/>
            </VerticalStackLayout>

        </Grid>

    </Grid>

</ContentPage>
